# Supabase connection (required for multi-device sync)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI API (für Whisper STT, ChatGPT Translation, TTS)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# Optional model tuning
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
OPENAI_TRANSLATE_TEMPERATURE=0
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SPELLCHECK_MODEL=gpt-4.1-mini
